[
    {
        "text": "所有的过去都是序章。",
        "author": "莎士比亚",
        "source": "《暴风雨》",
        "date": "2024-01-01",
        "mood": "思考"
    },
    {
        "text": "我们急于成长，然后又哀叹失去的童年。",
        "author": "佚名",
        "source": "",
        "date": "2024-03-15",
        "mood": "感怀"
    },
    {
        "text": "The best way out is always through.",
        "author": "Robert Frost",
        "source": "",
        "date": "2024-05-22",
        "mood": "励志"
    },
    {
        "text": "人生就像骑自行车，为了保持平衡，你必须保持前行。",
        "author": "爱因斯坦",
        "source": "书信",
        "date": "2024-07-08",
        "mood": "励志"
    },
    {
        "text": "不是因为事情难我们才不敢，而是因为我们不敢，事情才变得难。",
        "author": "塞内卡",
        "source": "",
        "date": "2024-09-01",
        "mood": "思考"
    },
    {
        "text": "万物并作，吾以观复。",
        "author": "老子",
        "source": "《道德经》",
        "date": "2024-11-11",
        "mood": "感怀"
    },
    {
        "text": "细节里住着魔鬼，也住着天使。",
        "author": "自己",
        "source": "",
        "date": "2025-02-14",
        "mood": "随想"
    }
]
